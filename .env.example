# Leaderboard API — overrides the local postgres in docker-compose when set
# DATABASE_URL=postgresql+asyncpg://user:pass@your-cluster-host:5432/leaderboard

# JWT signing secret — change this in production
JWT_SECRET=changeme

# Admin password reset endpoint secret — change this in production
ADMIN_SECRET=changeme

# Comma-separated list of origins allowed to call the API (CORS)
# CORS_ORIGINS=http://localhost:3000,https://pottmeier.github.io

# Frontend env (put this in frontend/.env.local for local dev)
# NEXT_PUBLIC_LEADERBOARD_URL=http://localhost:8000
